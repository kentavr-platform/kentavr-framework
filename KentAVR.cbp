		</Build>
		<Compiler>
			<Add option="-O1" />
			<Add option="-Wextra" />
			<Add option="-Wall" />
			<Add option="-std=c++17" />
			<Add option="-x c++" />
			<Add option="-save-temps=obj" />
			<Add option="-mmcu=$(MCU)" />
			<Add option="-DDEBUG" />
			<Add directory="." />
			<Add directory="AVR/GPIO/pins" />
		</Compiler>
		<Linker>
			<Add option="-mmcu=$(MCU)" />
			<Add option="-ffunction-sections" />
			<Add option="-fdata-sections" />
			<Add option="-fno-exceptions" />
			<Add option="-fno-rtti" />
			<Add option="-Wl,--gc-sections" />
			<Add option="-Wl,-Map=$(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).map" />
			<Add library="$MCU" />
		</Linker>
		<ExtraCommands>
			<Add after="chmod -x $(TARGET_OUTPUT_FILE)" />
			<Add after="avr-objdump -dzS $(TARGET_OUTPUT_FILE) &gt; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).asm" />
			<Add after="avr-strip --strip-debug -R .comment $(TARGET_OUTPUT_FILE)" />
			<Add after="avr-objcopy -j .eeprom --change-section-lma .eeprom=0 -O ihex $(TARGET_OUTPUT_FILE) $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).eep" />
			<Add after="avr-objcopy -j .fuse -O binary --interleave=3 --byte=0 $(TARGET_OUTPUT_FILE) $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).lfuse" />
			<Add after="avr-objcopy -j .fuse -O binary --interleave=3 --byte=1 $(TARGET_OUTPUT_FILE) $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).hfuse" />
			<Add after="avr-objcopy -j .fuse -O binary --interleave=3 --byte=2 $(TARGET_OUTPUT_FILE) $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).efuse" />
			<Add after="chmod -x $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).lfuse $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).hfuse $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).efuse" />
			<Add after="avr-objcopy -R .eeprom -R .fuse -R .lock -R .signature -O ihex $(TARGET_OUTPUT_FILE) $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).hex" />
			<Add after="avr-objdump -xC $(TARGET_OUTPUT_FILE) &gt; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).dump" />
			<Add after='grep -m1 &quot;.text  &quot; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).map &gt; $(TARGET_OUTPUT_DIR).text' />
			<Add after='grep -A 35 &quot;00000000&quot; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).asm &gt;&gt; $(TARGET_OUTPUT_DIR).text' />
			<Add after='grep &quot;F .text&quot; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).dump | sort &gt;&gt; $(TARGET_OUTPUT_DIR).text' />
			<Add after="avr-readelf -sW $(TARGET_OUTPUT_FILE) | grep OBJECT &gt; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).data || true" />
			<Add after="avr-size -C --mcu=$(MCU) -d $(TARGET_OUTPUT_FILE)" />
		</ExtraCommands>
