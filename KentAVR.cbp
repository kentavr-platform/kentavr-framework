<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="KentAVR" />
		<Option pch_mode="2" />
		<Option compiler="avr-gcc" />
		<Build>
			<Target title="ATmega1284p">
				<Option output="output/$(PROJECTNAME).elf" prefix_auto="1" extension_auto="0" />
				<Option working_dir="" />
				<Option object_output="." />
				<Option type="5" />
				<Option compiler="avr-gcc" />
				<Compiler>
					<Add option="-mmcu=atmega1284p" />
					<Add option="-g" />
					<Add option="-D__AVR_ATmega1284P__" />
					<Add directory="./" />
					<Add directory="Serial" />
					<Add directory="Console" />
					<Add directory="sensors/DS1820" />
					<Add directory="interfaces/OneWire" />
				</Compiler>
				<Environment>
					<Variable name="MCU" value="atmega1284p" />
					<Variable name="PROG" value="usbasp" />
				</Environment>
			</Target>
			<Target title="AVR128DB48">
				<Option output="output/$(PROJECTNAME).elf" prefix_auto="1" extension_auto="0" />
				<Option working_dir="" />
				<Option object_output="." />
				<Option type="5" />
				<Option compiler="avr-gcc" />
				<Compiler>
					<Add option="-g" />
					<Add option="-D__AVR_AVR128DB48__" />
					<Add directory="./" />
					<Add directory="Serial" />
					<Add directory="Console" />
					<Add directory="sensors/DS1820" />
					<Add directory="interfaces/OneWire" />
				</Compiler>
				<Environment>
					<Variable name="MCU" value="avr128db48" />
					<Variable name="PROG" value="usbasp" />
				</Environment>
			</Target>
			<Environment>
				<Variable name="ADAPTER" value="usbasp" />
				<Variable name="ADAPTER_PORT" value="" />
			</Environment>
		</Build>
		<Compiler>
			<Add option="-O1" />
			<Add option="-Wextra" />
			<Add option="-Wall" />
			<Add option="-std=c++17" />
			<Add option="-x c++" />
			<Add option="-save-temps=obj" />
			<Add option="-mmcu=$(MCU)" />
			<Add option="-DF_CPU=16000000UL" />
			<Add option="-DDEBUG" />
			<Add directory="include" />
		</Compiler>
		<Linker>
			<Add option="-mmcu=$(MCU)" />
			<Add option="-nodefaultlibs" />
			<Add option="-Wl,-Map=$(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).map" />
			<Add option="-Wl,--section-start=.eeprog=0x00810000" />
			<Add option="-Wl,--section-start=.eeprom=0x00810010" />
			<Add library="c" />
			<Add library="gcc" />
			<Add library="$MCU" />
		</Linker>
		<ExtraCommands>
			<Add after="avr-objdump -dzS $(TARGET_OUTPUT_FILE) &gt; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).asm" />
			<Add after="avr-strip --strip-debug -R .comment $(TARGET_OUTPUT_FILE)" />
			<Add after="# avr-objcopy -j .eeprom --change-section-lma .eeprom=0 -O ihex $(TARGET_OUTPUT_FILE) $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).eep" />
			<Add after="avr-objcopy -R .eeprom -R .fuse -R .lock -R .signature -O ihex $(TARGET_OUTPUT_FILE) $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).hex" />
			<Add after="avr-objdump -xC $(TARGET_OUTPUT_FILE) &gt; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).dump" />
			<Add after='grep -m1 &quot;.text  &quot; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).map &gt; $(TARGET_OUTPUT_DIR).text' />
			<Add after='grep -A 35 &quot;00000000&quot; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).asm &gt;&gt; $(TARGET_OUTPUT_DIR).text' />
			<Add after='grep &quot;F .text&quot; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).dump | sort &gt;&gt; $(TARGET_OUTPUT_DIR).text' />
			<Add after="avr-readelf -sW $(TARGET_OUTPUT_FILE) | grep OBJECT &gt; $(TARGET_OUTPUT_DIR)$(TARGET_OUTPUT_BASENAME).data || true" />
			<Add after="avr-size -C --mcu=$(MCU) -d $(TARGET_OUTPUT_FILE)" />
		</ExtraCommands>
		<Unit filename="AVR/EEPROM/avr-eeprom.cpp">
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="AVR/EEPROM/avr-eeprom.h" />
		<Unit filename="AVR/GPIO/avr-gpio.h" />
		<Unit filename="AVR/GPIO/avr-gpio.tpp" />
		<Unit filename="AVR/GPIO/pins.h" />
		<Unit filename="AVR/Serial/serial-bit-out.h" />
		<Unit filename="AVR/Serial/serial-bit-out.tpp" />
		<Unit filename="AVR/UART/avr-uart-regs.h" />
		<Unit filename="AVR/UART/avr-uart.h" />
		<Unit filename="AVR/UART/avr-uart.tpp" />
		<Unit filename="AVR/avr-delay.h" />
		<Unit filename="AVR/avr-macro.h" />
		<Unit filename="Console/console.h" />
		<Unit filename="Console/console.tpp" />
		<Unit filename="Console/debug.h" />
		<Unit filename="LED/led.h" />
		<Unit filename="LED/led.tpp" />
		<Unit filename="core.h" />
		<Unit filename="core/errors.h" />
		<Unit filename="core/type_traits.h" />
		<Unit filename="core/type_traits/is_enum.h" />
		<Unit filename="core/type_traits/is_floating.h" />
		<Unit filename="core/type_traits/is_function.h" />
		<Unit filename="core/type_traits/is_integer.h" />
		<Unit filename="core/type_traits/is_number.h" />
		<Unit filename="core/type_traits/is_pointer.h" />
		<Unit filename="core/units.h" />
		<Unit filename="interfaces/OneWire/one-wire.h" />
		<Unit filename="interfaces/OneWire/one-wire.tpp" />
		<Unit filename="main.cpp" />
		<Unit filename="sensors/DS1820/DS1820.h" />
		<Unit filename="sensors/DS1820/DS18x20.h" />
		<Unit filename="sensors/DS1820/DS18x20.tpp" />
		<Unit filename="sensors/DS18B20/DS18B20.h" />
		<Unit filename="sensors/DS18B20/DS18B20.tpp" />
		<Unit filename="sensors/DS18S20/DS18S20.h" />
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
